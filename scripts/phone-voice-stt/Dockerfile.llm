FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    software-properties-common && \
    add-apt-repository -y ppa:kobuk-team/intel-graphics && \
    apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    build-essential \
    curl \
    git \
    gpg \
    gpg-agent \
    libze-intel-gpu1 \
    intel-opencl-icd \
    python3 \
    python3-dev \
    python3-pip \
    python3-venv \
    wget && \
    update-alternatives --install /usr/bin/python python /usr/bin/python3 1 && \
    rm -rf /var/lib/apt/lists/*

RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:/app/.venv/bin:${PATH}"

WORKDIR /app
RUN git clone --depth 1 --branch v2.0.4 https://github.com/SearchSavior/OpenArc.git . && \
    uv sync && \
    uv pip install "optimum-intel[openvino] @ git+https://github.com/huggingface/optimum-intel" && \
    uv pip install --pre -U openvino-genai openvino-tokenizers \
      --extra-index-url https://storage.openvinotoolkit.org/simple/wheels/nightly

COPY scripts/phone-voice-stt/patch_openarc_qwen35.py /tmp/patch_openarc_qwen35.py
RUN python /tmp/patch_openarc_qwen35.py

COPY scripts/phone-voice-stt/entrypoint_llm.sh /entrypoint_llm.sh
RUN chmod +x /entrypoint_llm.sh && mkdir -p /models /persist

ENV LLM_PORT=8793 \
    LLM_MODEL_NAME=phone-voice-qwen3-4b \
    LLM_MODEL_REPO=OpenVINO/Qwen3-4B-int4-ov \
    LLM_WEIGHT_FORMAT=int4 \
    LLM_GROUP_SIZE=128 \
    LLM_DEVICE_TARGET=GPU.0 \
    HF_HOME=/models/hf-cache \
    OPENARC_API_KEY=phone-voice-local-openarc \
    OPENARC_API_KEY_REQUIRED=true \
    NEOReadDebugKeys=1 \
    OverrideGpuAddressSpace=48 \
    EnableImplicitScaling=1

EXPOSE 8793
HEALTHCHECK --interval=20s --timeout=5s --start-period=20s --retries=5 \
  CMD curl -fsS -H "Authorization: Bearer ${OPENARC_API_KEY}" "http://127.0.0.1:${LLM_PORT}/v1/models" >/dev/null || exit 1

ENTRYPOINT ["/entrypoint_llm.sh"]
