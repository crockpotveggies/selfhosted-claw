{
  "name": "nanoclaw",
  "version": "1.2.49",
  "description": "Personal assistant. Lightweight, secure, customizable.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run build:server && npm run build:ui",
    "build:server": "tsc",
    "build:ui": "vite build --config admin-ui/vite.config.ts",
    "start": "node dist/index.js",
    "service:install": "tsx setup/control-plane-service.ts install",
    "service:start": "tsx setup/control-plane-service.ts start",
    "service:stop": "tsx setup/control-plane-service.ts stop",
    "service:restart": "tsx setup/control-plane-service.ts restart",
    "service:logs": "tsx setup/control-plane-service.ts logs",
    "service:status": "tsx setup/control-plane-service.ts status",
    "service:cleanup-state": "tsx setup/control-plane-service.ts cleanup-state",
    "dev": "tsx src/index.ts",
    "dev:ui": "vite --config admin-ui/vite.config.ts",
    "typecheck": "npm run typecheck:server && npm run typecheck:ui",
    "typecheck:server": "tsc --noEmit",
    "typecheck:ui": "tsc --project admin-ui/tsconfig.json --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "setup": "tsx setup/index.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@coreui/icons": "^3.0.1",
    "@coreui/icons-react": "^2.3.0",
    "@coreui/react": "^5.10.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "11.10.0",
    "cron-parser": "5.5.0",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "react-bootstrap-icons": "^1.11.6",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.35.0",
    "eslint-plugin-no-catch-all": "^1.1.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-use-wizard": "^2.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.35.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
